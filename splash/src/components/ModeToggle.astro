---
/**
 * Three-mode toggle: dark (default — bench), light (field notebook),
 * vibrant (signal). Persists to localStorage. The inline script in BaseLayout
 * resolves the persisted mode pre-paint so there's no FOUC.
 */
---

<div class="mode-toggle" role="group" aria-label="Color mode">
  <button type="button" data-mode="light" aria-label="Field notebook (light)">
    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <circle cx="12" cy="12" r="4" />
      <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
    </svg>
  </button>
  <button type="button" data-mode="dark" aria-label="Bench (dark)">
    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
    </svg>
  </button>
  <button type="button" data-mode="vibrant" aria-label="Signal (vibrant)">
    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M12 2l2.39 4.84L20 8l-4 3.9.94 5.5L12 14.77 7.06 17.4 8 11.9 4 8l5.61-1.16L12 2z" />
    </svg>
  </button>
</div>

<script is:inline>
  (() => {
    const KEY = 'ai-labs-splash-mode';
    const root = document.documentElement;
    const apply = (mode) => {
      root.setAttribute('data-mode', mode);
      try { localStorage.setItem(KEY, mode); } catch {}
      document.querySelectorAll('.mode-toggle button').forEach((b) => {
        b.setAttribute('aria-pressed', b.dataset.mode === mode ? 'true' : 'false');
      });
    };
    const current = root.getAttribute('data-mode') || 'dark';
    document.querySelectorAll('.mode-toggle button').forEach((b) => {
      b.setAttribute('aria-pressed', b.dataset.mode === current ? 'true' : 'false');
      b.addEventListener('click', () => apply(b.dataset.mode));
    });
  })();
</script>

<style>
  .mode-toggle {
    display: inline-flex;
    gap: 2px;
    padding: 3px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border-strong);
    background: var(--color-bg-elevated);
  }
  .mode-toggle button {
    width: 30px;
    height: 30px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 0;
    border-radius: var(--radius-sm);
    color: var(--color-text-dim);
    cursor: pointer;
    transition: background var(--transition-fast), color var(--transition-fast);
  }
  .mode-toggle button:hover { color: var(--color-text); }
  .mode-toggle button[aria-pressed='true'] {
    background: var(--color-accent);
    color: var(--color-bg);
  }
</style>
