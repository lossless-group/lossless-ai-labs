---
import '@styles/theme.css';
import MetaTags from '@components/MetaTags.astro';
import Header from '@components/Header.astro';
import Analytics from '@components/Analytics.astro';
import { SITE_REPO } from '@lib/seo';

interface Props {
  title?: string;
  description?: string;
  /** Optional override for the body class list. Defaults to "bg-grid" — the
   *  blueprint-grid background applied to most pages. Pass an empty string to
   *  drop the grid (e.g. a /brand-kit reference page). */
  bodyClass?: string;
}

const { title, description, bodyClass = 'bg-grid' } = Astro.props;
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---
<!doctype html>
<html lang="en" data-mode="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <MetaTags title={title} description={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter+Tight:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" />

    {/* Pre-paint mode resolution — read persisted mode and apply to <html>
        before first paint to avoid FOUC. Inline, no module, runs blocking. */}
    <script is:inline>
      (() => {
        try {
          const KEY = 'ai-labs-splash-mode';
          const stored = localStorage.getItem(KEY);
          const valid = stored === 'light' || stored === 'dark' || stored === 'vibrant';
          if (valid) document.documentElement.setAttribute('data-mode', stored);
        } catch {}
      })();
    </script>

    <Analytics />
  </head>
  <body class={bodyClass}>
    <Header />
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <p>
          <span>Lossless AI-Labs</span>
          <span class="sep">·</span>
          <a href="https://lossless.group">lossless.group</a>
          <span class="sep">·</span>
          <a href={SITE_REPO}>github</a>
          <span class="sep">·</span>
          <span>© {year} The Lossless Group</span>
        </p>
        <p class="kicker">applied AI testbed becoming home to core products</p>
      </div>
    </footer>

    <style>
      .site-footer .sep { color: var(--color-text-faint); margin: 0 var(--space-2); }
      .site-footer .kicker { margin-top: var(--space-2); color: var(--color-text-faint); font-size: 0.74rem; letter-spacing: 0.12em; text-transform: uppercase; }
    </style>
  </body>
</html>
